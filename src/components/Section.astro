---
interface Props {
  id: string;
  number: string;
  title: string;
}

const { id, number, title } = Astro.props;
---

<section
  id={id}
  class="border-line scroll-mt-20 border-t py-16 md:py-24"
  aria-labelledby={`${id}-title`}
>
  <div class="mx-auto max-w-5xl px-5 md:px-8">
    <h2
      id={`${id}-title`}
      class="font-display text-ink text-3xl font-bold tracking-tight md:text-4xl"
      data-reveal
    >
      <span class="text-accent mr-3 align-middle text-base font-bold md:text-lg" aria-hidden="true">
        {number}
      </span>{title}
    </h2>
    <div class="mt-10">
      <slot />
    </div>
  </div>
</section>
