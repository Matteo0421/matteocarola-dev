---
import { getEducation, getJobs } from '../data/experience';
import { useTranslations } from '../i18n/ui';
import Section from './Section.astro';

const jobs = getJobs(Astro.currentLocale);
const education = getEducation(Astro.currentLocale);
const ui = useTranslations(Astro.currentLocale);
---

<Section id="esperienza" number="05" title={ui.sections.experience}>
  {
    jobs.map((job) => (
      <article>
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
          <h3 class="font-display text-ink text-xl font-bold md:text-2xl">
            {job.role} — {job.company}
          </h3>
          <p class="font-display text-ink-mute text-sm font-bold">{job.period}</p>
        </div>

        {/* Timeline: linea continua che si "disegna" quando entra in vista. */}
        <div class="relative mt-8 pl-7" data-reveal>
          <span class="tl-line" aria-hidden="true" />
          <span class="tl-draw" aria-hidden="true" />
          <div class="space-y-10">
            {job.phases.map((phase) => (
              <div class="relative">
                <span
                  class:list={[
                    'absolute top-1 -left-[34px] h-3.5 w-3.5 rounded-full border-2',
                    phase.current
                      ? "tl-node-now border-accent bg-bg after:bg-accent after:absolute after:inset-[3px] after:rounded-full after:content-['']"
                      : 'border-line bg-bg',
                  ]}
                  aria-hidden="true"
                />
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <h4 class="font-display text-ink text-base font-bold md:text-lg">
                    {phase.title}
                  </h4>
                  <p class="text-ink-mute text-sm">{phase.period}</p>
                  {phase.current && (
                    <span class="bg-accent/10 text-accent rounded-full px-2.5 py-0.5 text-[11px] font-semibold">
                      {ui.labels.current}
                    </span>
                  )}
                </div>
                <ul class="text-ink-soft mt-4 space-y-2.5 text-[15px] leading-relaxed" role="list">
                  {phase.bullets.map((bullet) => (
                    <li class="flex gap-3">
                      <span
                        class="bg-accent/60 mt-[11px] h-[3px] w-3 shrink-0"
                        aria-hidden="true"
                      />
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </article>
    ))
  }

  <h3 class="font-display text-ink mt-16 text-xl font-bold md:text-2xl" data-reveal>
    {ui.sections.education}
  </h3>
  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    {
      education.map((item, i) => (
        <article
          class="border-line rounded-xl border p-5"
          data-reveal
          style={`--reveal-delay:${i * 0.05}s`}
        >
          <div class="flex items-start justify-between gap-3">
            <h4 class="text-ink text-[15px] font-semibold">{item.title}</h4>
            {item.badge && (
              <span class="bg-accent/10 text-accent shrink-0 rounded-full px-2.5 py-0.5 text-[11px] font-semibold whitespace-nowrap">
                {item.badge}
              </span>
            )}
          </div>
          <p class="text-ink-soft mt-1.5 text-sm">{item.org}</p>
          <p class="text-ink-mute mt-1 text-[13px]">{item.period}</p>
        </article>
      ))
    }
  </div>
</Section>
