---
/**
 * Pagina Tech Radar, condivisa tra le due lingue. L'interfaccia è localizzata;
 * le CARD restano in italiano (contenuti d'attualità generati dalla pipeline).
 *
 * Struttura: radar SVG (blip cliccabili) → card recenti per esteso →
 * archivio raggruppato per mese in <details> nativi, così la pagina resta
 * corta anche con centinaia di card.
 */
import { getCollection } from 'astro:content';
import Footer from '../Footer.astro';
import Header from '../Header.astro';
import RadarCard from '../RadarCard.astro';
import RadarChart from '../RadarChart.astro';
import { asLocale, useTranslations } from '../../i18n/ui';
import Base from '../../layouts/Base.astro';

const locale = asLocale(Astro.currentLocale);
const ui = useTranslations(locale);

const entries = (await getCollection('radar')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const anchorIdOf = (id: string) => `card-${id.replace(/[^a-zA-Z0-9-]/g, '-')}`;

const blips = entries.map((entry) => ({
  anchorId: anchorIdOf(entry.id),
  title: entry.data.title,
  tags: entry.data.tags,
  pubDate: entry.data.pubDate,
}));

/* Recenti (≤35 giorni) per esteso — mai meno di 5, così la pagina non è
 * vuota nei periodi lenti; il resto va nell'archivio per mese. */
const now = Date.now();
const isRecent = (d: Date) => (now - d.valueOf()) / 86_400_000 <= 35;
const recentCount = Math.max(entries.filter((e) => isRecent(e.data.pubDate)).length, 5);
const recent = entries.slice(0, recentCount);
const archived = entries.slice(recentCount);

const monthFormat = new Intl.DateTimeFormat(locale === 'en' ? 'en-GB' : 'it-IT', {
  month: 'long',
  year: 'numeric',
});
const months: { label: string; items: typeof archived }[] = [];
for (const entry of archived) {
  const label = monthFormat.format(entry.data.pubDate);
  const bucket = months.at(-1);
  if (bucket && bucket.label === label) bucket.items.push(entry);
  else months.push({ label, items: [entry] });
}
---

<Base title={ui.radar.metaTitle} description={ui.radar.metaDescription}>
  <a
    href="#main"
    class="bg-accent text-on-accent fixed top-4 left-4 z-[100] -translate-y-24 rounded-md px-4 py-2 text-sm font-medium transition-transform focus:translate-y-0"
  >
    {ui.a11y.skipToContent}
  </a>
  <Header />
  <main id="main">
    <section class="relative overflow-hidden py-16 md:py-24" aria-labelledby="radar-title">
      <div class="hero-dots absolute inset-x-0 top-0 h-[420px]" aria-hidden="true"></div>
      <div class="relative mx-auto max-w-5xl px-5 md:px-8">
        <p
          class="text-accent hero-step text-xs font-semibold tracking-[0.18em] uppercase md:text-sm"
          style="--step-delay:.05s"
        >
          {ui.radarStrip.kicker}
        </p>
        <h1
          id="radar-title"
          class="font-display text-ink hero-step mt-4 text-4xl font-bold tracking-tight md:text-5xl"
          style="--step-delay:.15s"
        >
          {ui.radar.title}<span class="text-accent">.</span>
        </h1>
        <p
          class="text-ink-soft hero-step mt-5 max-w-3xl text-[15px] leading-relaxed md:text-base"
          style="--step-delay:.3s"
        >
          {ui.radar.intro}
        </p>
        <p
          class="text-ink-mute hero-step mt-3 max-w-3xl text-[13px] leading-relaxed"
          style="--step-delay:.4s"
        >
          {ui.radar.howItWorks}
        </p>

        {
          entries.length > 0 && (
            <div data-reveal>
              <RadarChart {blips} />
            </div>
          )
        }

        {/* h2 solo per screen reader: mantiene la gerarchia h1→h2→h3 delle card. */}
        <h2 class="sr-only">{ui.radar.latestTitle}</h2>
        <div class="border-line mt-12 border-t">
          {
            entries.length === 0 ? (
              <p class="text-ink-mute py-12 text-[15px]">{ui.radar.empty}</p>
            ) : (
              <div class="divide-line divide-y">
                {recent.map((entry, i) => (
                  <div data-reveal style={`--reveal-delay:${Math.min(i, 4) * 0.05}s`}>
                    <RadarCard {entry} anchorId={anchorIdOf(entry.id)} />
                  </div>
                ))}
              </div>
            )
          }
        </div>

        {
          months.length > 0 && (
            <div class="mt-4" data-reveal>
              <h2 class="font-display text-ink text-lg font-bold md:text-xl">
                {ui.radar.archiveTitle}
              </h2>
              <div class="border-line divide-line mt-4 divide-y border-t" id="radar-archive">
                {months.map(({ label, items }) => (
                  <details class="group py-1">
                    <summary class="text-ink-soft hover:text-ink flex cursor-pointer list-none items-center gap-3 py-4 text-[15px] font-medium capitalize transition-colors [&::-webkit-details-marker]:hidden">
                      <span
                        class="text-accent inline-block transition-transform group-open:rotate-90"
                        aria-hidden="true"
                      >
                        ▸
                      </span>
                      {label}
                      <span class="chip ml-auto normal-case">
                        {items.length} {ui.radar.cardsLabel}
                      </span>
                    </summary>
                    <div class="divide-line divide-y pl-6">
                      {items.map((entry) => (
                        <RadarCard {entry} anchorId={anchorIdOf(entry.id)} />
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Base>

<script>
  // Un blip può puntare a una card dentro un <details> chiuso: aprilo prima
  // di scrollare. Unico JS della pagina, pochi byte. Riagganciato ad ogni
  // astro:page-load perché con le view transitions il DOM viene ricreato.
  function openTarget() {
    const id = decodeURIComponent(location.hash.slice(1));
    if (!id) return;
    const target = document.getElementById(id);
    const details = target?.closest('details');
    if (details && !details.open) {
      details.open = true;
      target?.scrollIntoView();
    }
  }
  openTarget();
  document.addEventListener('astro:page-load', openTarget);
  window.addEventListener('hashchange', openTarget);
</script>
