---
/**
 * Widget "Chiedi a Matteo" — chatbot RAG sul contenuto del sito.
 *
 * Il markup (launcher + pannello) è statico e prerendered; la logica vive in
 * src/scripts/chat-panel.ts e viene caricata con un import dinamico SOLO alla
 * prima apertura, così le pagine restano a zero JS aggiuntivo fino al click.
 */
import { useTranslations } from '../i18n/ui';

const ui = useTranslations(Astro.currentLocale);

const strings = {
  thinking: ui.chat.thinking,
  errorGeneric: ui.chat.errorGeneric,
  errorRateLimited: ui.chat.errorRateLimited,
  errorQuota: ui.chat.errorQuota,
};
---

<div
  id="chat-widget"
  class="fixed right-4 bottom-4 z-50 sm:right-6 sm:bottom-6"
  data-strings={JSON.stringify(strings)}
>
  <section
    id="chat-panel"
    role="dialog"
    aria-label={ui.chat.title}
    hidden
    class="border-line bg-bg absolute right-0 bottom-16 flex h-[min(28rem,calc(100dvh-6rem))] w-[min(22rem,calc(100vw-2rem))] flex-col overflow-hidden rounded-xl border shadow-xl"
  >
    <header class="border-line flex items-center justify-between border-b px-4 py-3">
      <h2 class="font-display text-ink text-sm font-semibold">{ui.chat.title}</h2>
      <button
        id="chat-close"
        type="button"
        class="text-ink-soft hover:text-ink flex h-8 w-8 items-center justify-center rounded-md transition-colors"
        aria-label={ui.chat.close}
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </header>

    <div id="chat-messages" class="flex-1 space-y-3 overflow-y-auto px-4 py-4" aria-live="polite">
      <div
        class="border-line bg-bg-alt text-ink max-w-[85%] rounded-lg border px-3 py-2 text-sm leading-relaxed"
      >
        {ui.chat.intro}
      </div>
    </div>

    <form id="chat-form" class="border-line flex gap-2 border-t px-3 py-3">
      <label class="sr-only" for="chat-input">{ui.chat.placeholder}</label>
      <input
        id="chat-input"
        type="text"
        maxlength="500"
        autocomplete="off"
        placeholder={ui.chat.placeholder}
        class="border-line bg-bg text-ink placeholder:text-ink-mute min-w-0 flex-1 rounded-md border px-3 py-2 text-sm"
      />
      <button id="chat-send" type="submit" class="btn-primary px-4 py-2">
        {ui.chat.send}
      </button>
    </form>
    <p class="text-ink-mute px-4 pb-3 text-[11px] leading-4">{ui.chat.privacyNote}</p>
  </section>

  <button
    id="chat-launcher"
    type="button"
    class="bg-ink text-bg flex h-12 w-12 items-center justify-center rounded-full shadow-lg transition-transform hover:scale-105"
    aria-label={ui.chat.launcherLabel}
    aria-expanded="false"
    aria-controls="chat-panel"
  >
    <svg
      id="chat-icon-open"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
    </svg>
    <svg
      id="chat-icon-close"
      class="hidden"
      width="22"
      height="22"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      aria-hidden="true"
    >
      <path d="M18 6 6 18M6 6l12 12"></path>
    </svg>
  </button>

  {/* Template dei messaggi: clonati dal client, così le classi restano qui. */}
  <template id="chat-tpl-user">
    <div
      class="bg-ink text-bg ml-auto max-w-[85%] rounded-lg px-3 py-2 text-sm leading-relaxed break-words"
    >
    </div>
  </template>
  <template id="chat-tpl-bot">
    <div
      class="border-line bg-bg-alt text-ink max-w-[85%] rounded-lg border px-3 py-2 text-sm leading-relaxed break-words"
    >
    </div>
  </template>
  <template id="chat-tpl-thinking">
    <div
      class="border-line bg-bg-alt text-ink-mute max-w-[85%] animate-pulse rounded-lg border px-3 py-2 text-sm italic"
    >
    </div>
  </template>
</div>

<script>
  // Solo l'aggancio del launcher: il resto del JS arriva alla prima apertura.
  const launcher = document.getElementById('chat-launcher');
  launcher?.addEventListener('click', async () => {
    const { toggleChat } = await import('../scripts/chat-panel');
    toggleChat();
  });
</script>
