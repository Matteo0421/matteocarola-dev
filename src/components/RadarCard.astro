---
/**
 * Card del Tech Radar (usata sia tra le recenti sia nell'archivio per mese).
 * L'id è l'ancora a cui puntano i blip del radar; scroll-mt compensa
 * l'header sticky.
 */
import { render, type CollectionEntry } from 'astro:content';
import { asLocale, useTranslations } from '../i18n/ui';

interface Props {
  entry: CollectionEntry<'radar'>;
  anchorId: string;
}

const locale = asLocale(Astro.currentLocale);
const ui = useTranslations(locale);
const { entry, anchorId } = Astro.props;

const { Content } = await render(entry);
const hasNote = (entry.body ?? '').trim() !== '';

const dateFormat = new Intl.DateTimeFormat(locale === 'en' ? 'en-GB' : 'it-IT', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article id={anchorId} class="scroll-mt-20 py-8">
  <p class="text-ink-mute text-[13px]">
    <time datetime={entry.data.pubDate.toISOString().slice(0, 10)}>
      {dateFormat.format(entry.data.pubDate)}
    </time>
    <span aria-hidden="true"> · </span>
    <span>{entry.data.sourceName}</span>
  </p>
  <h3 class="font-display text-ink mt-2 text-xl font-bold md:text-2xl">
    <a
      href={entry.data.sourceUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="hover:text-accent transition-colors"
    >
      {entry.data.title}
      <span class="text-accent ml-1 text-base" aria-hidden="true">↗</span>
    </a>
  </h3>
  <p class="text-ink-soft mt-3 max-w-3xl text-[15px] leading-relaxed">
    {entry.data.summary}
  </p>
  {
    hasNote && (
      <div class="border-accent mt-4 max-w-3xl border-l-2 pl-4">
        <p class="text-accent text-[12px] font-semibold tracking-wide uppercase">
          {ui.radar.noteLabel}
        </p>
        <div class="text-ink-soft mt-1 text-[15px] leading-relaxed italic">
          <Content />
        </div>
      </div>
    )
  }
  <ul class="mt-5 flex flex-wrap gap-2" role="list">
    {entry.data.tags.map((tag) => <li class="chip">{tag}</li>)}
  </ul>
</article>
