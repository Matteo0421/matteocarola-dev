---
import { asLocale, localizedPath, useTranslations } from '../i18n/ui';
import ThemeToggle from './ThemeToggle.astro';

const locale = asLocale(Astro.currentLocale);
const ui = useTranslations(locale);
const homeHref = locale === 'en' ? '/en/' : '/';
// Toggle lingua: link alla versione dell'altra lingua della pagina corrente.
const otherLocale = locale === 'en' ? 'it' : 'en';
const otherHref = localizedPath(Astro.url.pathname, otherLocale);
const otherLabel = otherLocale.toUpperCase();
---

<header class="border-line bg-bg/85 sticky top-0 z-50 border-b backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between px-5 md:px-8">
    <a href={homeHref} class="font-display text-lg font-bold tracking-tight">
      MC<span class="text-accent">·</span>
    </a>

    <div class="flex items-center gap-3">
      <nav aria-label={ui.a11y.mainNav} class="hidden md:block">
        <ul class="flex items-center gap-6">
          {
            ui.nav.map((item, i) => (
              <li>
                <a
                  href={item.href}
                  class="text-ink-soft hover:text-ink text-[13px] font-medium transition-colors"
                >
                  <span class="font-display text-accent text-[11px] font-bold" aria-hidden="true">
                    0{i + 1}
                  </span>
                  <span class="ml-1">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <a
        href={otherHref}
        class="border-line text-ink-soft hover:border-ink-mute hover:text-ink flex h-9 items-center justify-center rounded-md border px-2.5 text-[13px] font-semibold transition-colors"
        aria-label={ui.a11y.switchLanguage}
        hreflang={otherLocale}
      >
        {otherLabel}
      </a>

      <ThemeToggle />

      <details id="mobile-nav" class="relative md:hidden">
        <summary
          class="border-line text-ink-soft flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-md border [&::-webkit-details-marker]:hidden"
          aria-label={ui.a11y.openMenu}
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M4 7h16M4 12h16M4 17h16"></path>
          </svg>
        </summary>
        <nav
          class="border-line bg-bg absolute right-0 mt-3 w-52 rounded-lg border p-2 shadow-lg"
          aria-label={ui.a11y.mainNav}
        >
          <ul>
            {
              ui.nav.map((item, i) => (
                <li>
                  <a
                    href={item.href}
                    class="text-ink-soft hover:bg-bg-alt hover:text-ink block rounded-md px-3 py-2 text-sm font-medium transition-colors"
                  >
                    <span class="font-display text-accent text-xs font-bold" aria-hidden="true">
                      0{i + 1}
                    </span>
                    <span class="ml-2">{item.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<script>
  const details = document.getElementById('mobile-nav');
  details
    ?.querySelectorAll('a')
    .forEach((link) => link.addEventListener('click', () => details.removeAttribute('open')));
</script>
