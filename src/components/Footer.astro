---
import { profile } from '../data/profile';
import { ui } from '../i18n/ui';

const year = new Date().getFullYear();
---

<footer class="border-line border-t">
  <div
    class="text-ink-mute mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-x-6 gap-y-2 px-5 py-8 text-[13px] md:px-8"
  >
    <p>© {year} {profile.name}</p>
    <p class="flex flex-wrap items-center gap-x-4 gap-y-1">
      <span>
        {ui.footer.madeWith}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="text-ink-soft hover:text-accent font-medium">Astro</a
        >
      </span>
      <a
        href={profile.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-ink-soft hover:text-accent font-medium"
      >
        {ui.footer.source} ↗
      </a>
      <a href="/privacy" class="text-ink-soft hover:text-accent font-medium">{ui.footer.privacy}</a>
      <span>{ui.footer.noCookies}</span>
    </p>
  </div>
</footer>
